<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>The Daily Brief · Vol. {{ issue_number }}</title>
<style>
*, *::before, *::after { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
body {
  font-family: "Playfair Display", "Merriweather", "Noto Serif KR", Georgia, "Times New Roman", serif;
  background: #f5f0e6;
  color: #17110a;
  line-height: 1.52;
}
a { color: inherit; text-decoration: none; }
a:hover { text-decoration: underline; text-underline-offset: 3px; }

.masthead {
  max-width: 1100px; margin: 0 auto; padding: 2.5rem 2rem 1rem;
  text-align: center; border-bottom: 2px double #17110a;
}
.masthead .super {
  font-family: "Helvetica", sans-serif; font-size: 0.72rem; letter-spacing: 0.3em;
  text-transform: uppercase; color: #5a4a35;
}
.masthead h1 {
  font-size: clamp(2.4rem, 5.5vw, 4.2rem); font-weight: 900;
  letter-spacing: -0.01em; margin: 0.4rem 0 0.3rem;
  font-family: "Playfair Display", Georgia, serif;
}
.masthead .sub {
  font-family: "Helvetica", sans-serif; font-size: 0.76rem; letter-spacing: 0.15em;
  text-transform: uppercase; color: #5a4a35; margin-top: 0.5rem;
}

.dateline {
  max-width: 1100px; margin: 0 auto; padding: 0.5rem 2rem;
  display: flex; justify-content: space-between;
  font-family: "Helvetica", sans-serif; font-size: 0.7rem;
  letter-spacing: 0.15em; text-transform: uppercase; color: #7a6a55;
  border-bottom: 1px solid #17110a;
}

.lede {
  max-width: 1100px; margin: 2.5rem auto; padding: 0 2rem;
  display: grid; grid-template-columns: 2fr 1fr; gap: 2.5rem;
}
.lede-main .kicker {
  font-family: "Helvetica", sans-serif; font-size: 0.75rem; letter-spacing: 0.2em;
  text-transform: uppercase; color: #a02020; font-weight: 700; margin-bottom: 0.5rem;
}
.lede-main h2 {
  font-size: clamp(1.8rem, 3.6vw, 2.8rem); font-weight: 900;
  letter-spacing: -0.015em; line-height: 1.1; margin: 0 0 1rem;
}
.lede-main .byline {
  font-family: "Helvetica", sans-serif; font-size: 0.78rem;
  color: #5a4a35; margin-bottom: 1.2rem;
}
.lede-main .body {
  column-count: 1; font-size: 1.05rem;
}
.lede-main .body::first-letter {
  font-size: 4.5rem; float: left; line-height: 0.9; font-weight: 900;
  margin: 0.4rem 0.5rem 0 0; color: #a02020;
}
.lede-side {
  border-left: 1px solid #17110a; padding-left: 1.2rem;
}
.lede-side h3 {
  font-family: "Helvetica", sans-serif; font-size: 0.7rem;
  letter-spacing: 0.2em; text-transform: uppercase; font-weight: 700;
  margin: 0 0 0.7rem; color: #5a4a35;
}
.lede-side ul { list-style: none; margin: 0; padding: 0; }
.lede-side li { border-bottom: 1px solid #d6cdbb; padding: 0.7rem 0; }
.lede-side li:last-child { border-bottom: none; }
.lede-side li a {
  font-size: 0.94rem; font-weight: 700; line-height: 1.25; display: block;
}
.lede-side li .meta {
  font-family: "Helvetica", sans-serif; font-size: 0.66rem;
  color: #7a6a55; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.2rem;
}

.section {
  max-width: 1100px; margin: 3rem auto; padding: 0 2rem;
}
.section-head {
  border-top: 2px solid #17110a; padding-top: 0.8rem; margin-bottom: 1rem;
  display: flex; justify-content: space-between; align-items: baseline;
}
.section-head h2 {
  font-family: "Playfair Display", Georgia, serif; font-size: 1.8rem;
  font-weight: 900; margin: 0;
}
.section-head .num {
  font-family: "Helvetica", sans-serif; font-size: 0.7rem;
  color: #7a6a55; letter-spacing: 0.15em; text-transform: uppercase;
}
.columns {
  column-count: 3; column-gap: 2rem; column-rule: 1px solid #d6cdbb;
}
.article {
  break-inside: avoid; margin-bottom: 1.8rem; padding-bottom: 1rem;
  border-bottom: 1px solid #d6cdbb;
}
.article:last-child { border-bottom: none; }
.article .kicker {
  font-family: "Helvetica", sans-serif; font-size: 0.65rem;
  letter-spacing: 0.2em; text-transform: uppercase; color: #a02020;
  font-weight: 700; margin-bottom: 0.3rem;
}
.article h4 {
  font-size: 1.12rem; font-weight: 800; line-height: 1.2; margin: 0 0 0.5rem;
}
.article .byline {
  font-family: "Helvetica", sans-serif; font-size: 0.7rem;
  color: #7a6a55; margin-bottom: 0.5rem;
}
.article p { font-size: 0.92rem; margin: 0; }

.back-link {
  display: inline-block; margin: 2rem;
  padding: 0.5rem 1rem; border: 1px solid #17110a;
  font-family: "Helvetica", sans-serif; font-size: 0.8rem;
  letter-spacing: 0.1em; text-transform: uppercase;
}

footer {
  max-width: 1100px; margin: 3rem auto; padding: 2rem;
  border-top: 2px solid #17110a;
  font-family: "Helvetica", sans-serif; font-size: 0.78rem;
  color: #5a4a35; text-align: center;
}

@media (max-width: 820px) {
  .lede { grid-template-columns: 1fr; }
  .lede-side { border-left: none; border-top: 1px solid #17110a; padding-left: 0; padding-top: 1rem; }
  .columns { column-count: 1; }
}
</style>
</head>
<body>

<header class="masthead">
  <div class="super">모든 뉴스, 깊이 있게</div>
  <h1>The Daily Brief</h1>
  <div class="sub">Independent · Curated · Grounded Analysis</div>
</header>

<div class="dateline">
  <span>Vol. {{ issue_number }} · {{ period_label }} 에디션</span>
  <span>{{ generation_timestamp }}</span>
</div>

{% if must_know and must_know|length > 0 %}
{% set lede = must_know[0] %}
<section class="lede">
  <article class="lede-main">
    <div class="kicker">■ Front Page · {{ lede.source }}</div>
    <h2>{{ lede.title }}</h2>
    <div class="byline">By {{ lede.source }} · {{ lede.published_at_display }} · Score {{ '%.1f' % lede.relevance_score }}</div>
    <div class="body">{{ lede.ai_summary }}</div>
  </article>
  <aside class="lede-side">
    <h3>오늘의 브리핑 키워드</h3>
    <ul>
      {% for h in trend_hashtags[:8] %}
      <li>
        <a href="#">#{{ h }}</a>
        <div class="meta">Trending</div>
      </li>
      {% endfor %}
    </ul>
  </aside>
</section>
{% endif %}

{% if must_know and must_know|length > 1 %}
<section class="section">
  <div class="section-head">
    <h2>꼭 알아야 할 뉴스</h2>
    <span class="num">{{ must_know|length }}건</span>
  </div>
  <div class="columns">
    {% for art in must_know[1:] %}
    <article class="article">
      <div class="kicker">{{ art.source }}</div>
      <h4><a href="{{ art.original_url }}" target="_blank" rel="noopener">{{ art.title }}</a></h4>
      <div class="byline">{{ art.published_at_display }} · 중요도 {{ '%.1f' % art.relevance_score }}</div>
      <p>{{ art.ai_summary[:220] }}{% if art.ai_summary|length > 220 %}…{% endif %}</p>
    </article>
    {% endfor %}
  </div>
</section>
{% endif %}

{% for sec in sections %}
{% if sec.articles %}
<section class="section">
  <div class="section-head">
    <h2>{{ sec.title }}</h2>
    <span class="num">{{ sec.articles|length }}건</span>
  </div>
  <div class="columns">
    {% for art in sec.articles[:18] %}
    <article class="article">
      <div class="kicker">{{ art.source }}</div>
      <h4><a href="{{ art.original_url }}" target="_blank" rel="noopener">{{ art.title }}</a></h4>
      <div class="byline">{{ art.published_at_display }}</div>
      <p>{{ art.ai_summary[:180] }}{% if art.ai_summary|length > 180 %}…{% endif %}</p>
    </article>
    {% endfor %}
  </div>
</section>
{% endif %}
{% endfor %}

<a class="back-link" href="./index.html">← Gallery</a>

<footer>
  The Daily Brief · Vol. {{ issue_number }} · 발행 {{ generation_timestamp }}<br>
  "All the news that's fit to reason about."
</footer>

</body>
</html>
