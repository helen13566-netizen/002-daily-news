<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>DAILY::BRIEF #{{ issue_number }} — TERMINAL</title>
<style>
:root {
  --bg: #0a0a0a;
  --panel: #111111;
  --border: #222;
  --text: #d8d6cf;
  --dim: #6e6c66;
  --green: #00ff88;
  --amber: #ffb300;
  --red: #ff3b3b;
  --cyan: #29e3ff;
  --magenta: #ff2bd8;
}
*, *::before, *::after { box-sizing: border-box; }
html, body { margin: 0; padding: 0; background: var(--bg); color: var(--text); }
body {
  font-family: "JetBrains Mono", "Fira Code", "IBM Plex Mono", "Menlo",
               "D2Coding", "Nanum Gothic Coding", monospace;
  font-size: 13.5px; line-height: 1.55;
  background-image:
    repeating-linear-gradient(0deg, rgba(255,255,255,0.015) 0 1px, transparent 1px 3px);
}
a { color: var(--cyan); text-decoration: none; }
a:hover { color: var(--amber); text-decoration: underline; }

.scanline {
  position: fixed; top: 0; left: 0; right: 0; height: 100vh;
  background: repeating-linear-gradient(
    180deg, rgba(0,255,136,0.02) 0 1px, transparent 1px 4px
  );
  pointer-events: none; z-index: 100;
}

.header {
  border-bottom: 1px solid var(--border);
  padding: 0.6rem 1.2rem; display: flex; justify-content: space-between;
  align-items: center; background: #050505;
}
.header .logo {
  font-weight: 900; color: var(--green); letter-spacing: 0.1em;
}
.header .logo::before { content: "▌ "; color: var(--amber); }
.header .stat { color: var(--dim); font-size: 0.85em; }
.header .stat b { color: var(--text); }
.cursor {
  display: inline-block; width: 9px; height: 15px; background: var(--green);
  animation: blink 1s step-end infinite; vertical-align: text-bottom;
}
@keyframes blink { 0%,50% { opacity: 1; } 51%,100% { opacity: 0; } }

.ticker {
  background: #0d0d0d; border-bottom: 1px solid var(--border);
  overflow: hidden; white-space: nowrap; padding: 0.5rem 0;
  font-size: 0.85em; color: var(--amber);
}
.ticker-track {
  display: inline-block; padding-left: 100%;
  animation: tick 40s linear infinite;
}
.ticker-track span { margin: 0 2rem; }
.ticker-track span::before { content: "◆ "; color: var(--green); }
@keyframes tick { 0% { transform: translateX(0); } 100% { transform: translateX(-100%); } }

.top-panel {
  display: grid; grid-template-columns: 2fr 1fr; gap: 1px;
  background: var(--border);
}
.panel {
  background: var(--panel); padding: 1rem 1.2rem;
}
.panel-title {
  display: flex; justify-content: space-between; align-items: center;
  border-bottom: 1px dashed var(--border); padding-bottom: 0.4rem;
  margin-bottom: 0.8rem; color: var(--green);
  font-size: 0.8em; letter-spacing: 0.15em; text-transform: uppercase;
}
.panel-title .id { color: var(--dim); }

.lede h2 {
  font-size: 1.4em; font-weight: 700; color: var(--amber);
  margin: 0 0 0.5rem; line-height: 1.2;
}
.lede .meta { color: var(--dim); font-size: 0.88em; margin-bottom: 0.8rem; }
.lede .meta .severity { color: var(--red); font-weight: 700; }
.lede p { margin: 0.6rem 0; font-size: 0.95em; }

.hashtag-strip {
  padding: 0.5rem 1.2rem; background: #0d0d0d;
  border-bottom: 1px solid var(--border);
  font-size: 0.8em; color: var(--magenta);
}
.hashtag-strip span { margin-right: 1.2rem; }

.table-wrap {
  background: var(--panel); padding: 0 0.4rem;
}
.table-title {
  padding: 1rem 1.2rem 0.5rem; color: var(--green);
  font-size: 0.85em; letter-spacing: 0.12em; text-transform: uppercase;
  border-top: 1px solid var(--border);
}
table {
  width: 100%; border-collapse: collapse; font-size: 0.9em;
}
thead th {
  text-align: left; font-weight: 700; color: var(--dim);
  font-size: 0.78em; letter-spacing: 0.12em; text-transform: uppercase;
  border-bottom: 1px solid var(--border); padding: 0.5rem 0.8rem;
}
tbody td {
  border-bottom: 1px solid #1a1a1a; padding: 0.6rem 0.8rem;
  vertical-align: top;
}
tbody tr:hover td { background: #161616; color: var(--green); }
tbody tr:hover a { color: var(--green); }
.col-time { color: var(--amber); font-variant-numeric: tabular-nums; white-space: nowrap; }
.col-src {
  color: var(--cyan); text-transform: uppercase;
  font-size: 0.8em; letter-spacing: 0.08em;
}
.col-score { font-weight: 700; text-align: right; font-variant-numeric: tabular-nums; }
.score-high { color: var(--red); }
.score-mid { color: var(--amber); }
.score-low { color: var(--dim); }
.col-title { font-weight: 500; }
.col-title a { display: block; }
.col-title .sub { color: var(--dim); font-size: 0.85em; margin-top: 0.3rem; }

.section-head {
  background: #050505; padding: 0.8rem 1.2rem;
  border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
  display: flex; justify-content: space-between;
  color: var(--green); font-size: 0.88em;
  letter-spacing: 0.15em; text-transform: uppercase;
}
.section-head .count { color: var(--dim); }
.section-head .count b { color: var(--amber); }

.back-link {
  display: inline-block; margin: 1.5rem 1.2rem;
  padding: 0.5rem 1rem; border: 1px solid var(--green); color: var(--green);
  font-size: 0.82em; letter-spacing: 0.12em; text-transform: uppercase;
}
.back-link:hover { background: var(--green); color: var(--bg); }

footer {
  padding: 1.5rem 1.2rem; color: var(--dim);
  font-size: 0.82em; border-top: 1px solid var(--border);
}

@media (max-width: 820px) {
  .top-panel { grid-template-columns: 1fr; }
  body { font-size: 12.5px; }
}
</style>
</head>
<body>
<div class="scanline"></div>

<header class="header">
  <div class="logo">DAILY::BRIEF TERMINAL v{{ issue_number }}</div>
  <div class="stat">
    [{{ generation_timestamp }}] &nbsp; PERIOD=<b>{{ period_label }}</b> &nbsp;
    ARTICLES=<b>{{ all_count }}</b> &nbsp; MUST_KNOW=<b>{{ must_know|length }}</b>
    <span class="cursor"></span>
  </div>
</header>

{% if trend_hashtags %}
<div class="ticker">
  <div class="ticker-track">
    {% for h in trend_hashtags %}<span>#{{ h }}</span>{% endfor %}
    {% for h in trend_hashtags %}<span>#{{ h }}</span>{% endfor %}
  </div>
</div>
{% endif %}

{% if must_know %}
{% set lede = must_know[0] %}
<div class="top-panel">
  <section class="panel lede">
    <div class="panel-title">
      <span>▲ TOP STORY</span>
      <span class="id">ID::{{ lede.article_id }}</span>
    </div>
    <h2>{{ lede.title }}</h2>
    <div class="meta">
      SRC: <span style="color: var(--cyan)">{{ lede.source }}</span> ·
      PUB: {{ lede.published_at_display }} ·
      SEV: <span class="severity">{{ '%.1f' % lede.relevance_score }}/10</span>
    </div>
    <p>> {{ lede.ai_summary[:320] }}{% if lede.ai_summary|length > 320 %}…{% endif %}</p>
    <p style="color: var(--dim)">// WHY: {{ lede.extraction_reason[:180] }}{% if lede.extraction_reason|length > 180 %}…{% endif %}</p>
  </section>
  <section class="panel">
    <div class="panel-title">
      <span>▶ WATCHLIST</span>
      <span class="id">SORT::RELEVANCE</span>
    </div>
    {% for art in must_know[1:6] %}
    <div style="border-bottom: 1px dashed var(--border); padding: 0.55rem 0;">
      <div style="color: var(--amber); font-size: 0.88em;">{{ art.title[:60] }}{% if art.title|length > 60 %}…{% endif %}</div>
      <div style="color: var(--dim); font-size: 0.78em; margin-top: 0.25rem;">
        {{ art.source }} · {{ art.published_at_display }} · <span class="{% if art.relevance_score >= 8 %}score-high{% elif art.relevance_score >= 5 %}score-mid{% else %}score-low{% endif %}">{{ '%.1f' % art.relevance_score }}</span>
      </div>
    </div>
    {% endfor %}
  </section>
</div>
{% endif %}

{% for sec in sections %}
{% if sec.articles %}
<div class="section-head">
  <span>█ {{ sec.title }}</span>
  <span class="count">COUNT: <b>{{ sec.articles|length }}</b></span>
</div>
<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th style="width: 90px;">TIME</th>
        <th style="width: 110px;">SRC</th>
        <th>TITLE · SUMMARY</th>
        <th style="width: 70px; text-align: right;">SCORE</th>
      </tr>
    </thead>
    <tbody>
      {% for art in sec.articles[:20] %}
      <tr>
        <td class="col-time">{{ art.published_at_display }}</td>
        <td class="col-src">{{ art.source }}</td>
        <td class="col-title">
          <a href="{{ art.original_url }}" target="_blank" rel="noopener">{{ art.title }}</a>
          <div class="sub">{{ art.ai_summary[:120] }}{% if art.ai_summary|length > 120 %}…{% endif %}</div>
        </td>
        <td class="col-score {% if art.relevance_score >= 8 %}score-high{% elif art.relevance_score >= 5 %}score-mid{% else %}score-low{% endif %}">
          {{ '%.1f' % art.relevance_score }}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}
{% endfor %}

<a class="back-link" href="./index.html">◀ ESC :: GALLERY</a>

<footer>
  -- DAILY::BRIEF TERMINAL · END OF FEED · {{ generation_timestamp }} --<br>
  &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;ready<span class="cursor"></span>
</footer>

</body>
</html>
